datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id       String @id @default(uuid())
  document String @unique
  balance  Int

  createdAt DateTime @default(now())

  outgoingTransactions Transaction[] @relation("sender")
  incomingTransactions Transaction[] @relation("receiver")
}

model Transaction {
  id String @id @default(uuid())

  senderId   String
  receiverId String

  amount Int
  type   String

  createdAt DateTime @default(now())

  sender   Account @relation("sender", fields: [senderId], references: [id])
  receiver Account @relation("receiver", fields: [receiverId], references: [id])
}
